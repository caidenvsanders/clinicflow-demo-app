{
  "name": "healthcare-appointment-scheduling-demo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "db:up": "docker compose up -d postgres appointment-scheduler",
    "db:browser": "docker compose --profile dev up -d adminer",
    "db:browser:down": "docker compose --profile dev stop adminer",
    "db:schema": "node scripts/schema.mjs",
    "db:seed": "node scripts/seed.mjs",
    "db:reset": "node scripts/reset-db.mjs",
    "db:reset:seed": "node scripts/reset-db.mjs"
  },
  "dependencies": {
    "lucide-react": "0.468.0",
    "next": "^16.2.4",
    "pg": "8.13.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/pg": "8.11.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "10.4.20",
    "eslint": "9.17.0",
    "eslint-config-next": "^16.2.4",
    "postcss": "8.4.49",
    "pptxgenjs": "^4.0.1",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2"
  }
}
